# Environment variables for Studyo Client

# Firebase Configuration (Get these from Firebase Console -> Project Settings)
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=studyo-manager.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=studyo-manager
VITE_FIREBASE_STORAGE_BUCKET=studyo-manager.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Hosting URL (for Electron Stealth Mode)
FIREBASE_HOSTING_URL=https://studyo-manager.web.app

# Firebase AppCheck (reCAPTCHA v3 site key)
# Leave empty to disable AppCheck initialization client-side.
# Get the site key from Google reCAPTCHA admin -> v3 site, then register it
# in Firebase Console -> App Check. See firebase/APPCHECK_SETUP.md for flow.
VITE_APPCHECK_SITE_KEY=
